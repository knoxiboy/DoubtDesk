# ==============================================================================
# E2E Test Environment Variables
# Copy this file to .env.e2e and fill in the values.
# ==============================================================================

# Clerk credentials (use a development/test Clerk instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Database (use a test database, NOT production)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Groq (optional — AI chat tests will skip if not set)
GROQ_API_KEY=gsk_...

# Supabase (for file upload tests)
NEXT_PUBLIC_SUPABASE_URL=https://project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=anon_key_here

# Test user credentials (these must exist in your Clerk instance)
E2E_TEST_EMAIL=e2e-test@doubtdesk.dev
E2E_TEST_PASSWORD=E2eTestPass123!
E2E_TEST_ROLE=teacher

# Optional: invite code for join testing
E2E_TEST_INVITE_CODE=
